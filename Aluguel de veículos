<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Aluguel de Veículos - Rafael Sampaio</title>
    <style>
        body { font-family: sans-serif; padding: 20px; background: #f4f4f4; }
        .container { background: white; padding: 20px; border-radius: 8px; max-width: 500px; margin: auto; }
        input, button { width: 100%; padding: 10px; margin-top: 10px; }
        button { background: #28a745; color: white; border: none; cursor: pointer; }
        #mensagem { margin-top: 20px; padding: 10px; border: 1px solid #ddd; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Simular Reserva de Veículo</h2>
        <input type="number" id="veiculoId" placeholder="ID do Veículo (ex: 1)">
        <input type="number" id="clienteId" placeholder="ID do Cliente (ex: 1)">
        <input type="date" id="dataIni">
        <input type="date" id="dataFim">
        <button onclick="fazerReserva()">Confirmar Reserva</button>
        
        <div id="mensagem">Status do sistema: Aguardando ação...</div>
    </div>

    <script>
        async function fazerReserva() {
            const dados = {
                veiculoId: document.getElementById('veiculoId').value,
                clienteId: document.getElementById('clienteId').value,
                dataIni: document.getElementById('dataIni').value,
                dataFim: document.getElementById('dataFim').value
            };

            const divMsg = document.getElementById('mensagem');
            
            try {
                const response = await fetch('/api/reservas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dados)
                });

                const resultado = await response.json();

                if (response.ok) {
                    divMsg.style.color = 'green';
                    divMsg.innerHTML = `<strong>Sucesso!</strong><br>Reserva ID: ${resultado.id}<br>Valor Total: R$ ${resultado.valorTotal}`;
                } else {
                    divMsg.style.color = 'red';
                    divMsg.innerHTML = `<strong>Erro:</strong> ${resultado.error}`;
                }
            } catch (err) {
                divMsg.innerHTML = "Erro ao conectar com o servidor.";
            }
        }
    </script>
</body>
</html>



